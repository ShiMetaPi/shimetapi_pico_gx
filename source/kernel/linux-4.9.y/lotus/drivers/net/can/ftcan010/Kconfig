config CAN_FTCAN
	tristate "FTCAN support"
	select FTCAN_CALC_BITTIMING
	help
	  Say Y here if you want support for Lotus FT_CAN controller framework.
	  This is common support for devices that embed the Lotus FT_CAN IP.

if CAN_FTCAN
menu "FTCAN config"
config FTCAN_CALC_BITTIMING
	bool "FTCAN bit-timing calculation"
	default y
	help
	  If enabled, CAN bit-timing parameters will be calculated for the
	  bit-rate specified via Netlink argument "bitrate" when the device
	  get started. This works fine for the most common CAN controllers
	  with standard bit-rates but may fail for exotic bit-rates or CAN
	  source clock frequencies. Disabling saves some space, but then the
	  bit-timing parameters must be specified directly using the Netlink
	  arguments "tq", "prop_seg", "phase_seg1", "phase_seg2" and "sjw".
	  If unsure, say Y.

config FTCAN_SUPPORT_OVERLOAD_FRAME
	bool "FTCAN support overload frame"
	default y
	help
	  If enabled, CAN will transmit 1 overload fame for RX FIFO full
	  condition.
	  If unsure, say Y.

choice
	prompt "Choose retransmission times"
	default RETRANSMITTED_3_TIMES
	help
	  Choose retransmission times control due to arbitration
	  loss and errors.

	config ALWAYS_RETRANSMITTED
		bool "Message will always be retransmitted"
	config NEVER_RETRANSMITTED
		bool "Message will not be retransmitted"
	config RETRANSMITTED_3_TIMES
		bool "Message will be retransmitted at most 3 times"
	config RETRANSMITTED_8_TIMES
		bool "Message will be retransmitted at most 8 times"
endchoice

config FTCAN_RETRANSMISSION_TIMES
	int
	default 0 if ALWAYS_RETRANSMITTED
	default 1 if NEVER_RETRANSMITTED
	default 2 if RETRANSMITTED_3_TIMES
	default 3 if RETRANSMITTED_8_TIMES

endmenu
endif
