		rtc: rtc@120e0000 {
			compatible = "lotus,rtc";
			reg = <0x120e0000 0x1000>;
			interrupts = <0 0 4>;
		};

		cipher: cipher@0x10050000 {
			compatible = "lotus,cipher";
			reg = <0x10050000 0x10000>;
			reg-names = "cipher";
			interrupts = <0 53 4>, <0 53 4>;
			interrupt-names = "cipher", "hash";
		};

		adc: adc@120a0000 {
			compatible = "lotus,lsadc";
			reg = <0x120a0000 0x1000>;
			interrupts = <0 6 4>;
			interrupt-names = "adc";
			resets = <&clock 0x1bc 2>;
			reset-names = "lsadc-crg";
			status = "okay";
		};

		ir: ir@0x12090000 {
			compatible = "lotus,ir";
			reg = <0x12090000 0x10000>;
			reg-names = "ir";
			interrupts = <0 5 4>;
			interrupt-names = "ir";
		};
	};

	media {
		#address-cells = <1>;
		#size-cells = <1>;
		compatible = "simple-bus";
		interrupt-parent = <&gic>;
		ranges;

		osal: osal {
			compatible = "lotus,osal";
		};

		sys: sys@12010000 {
			compatible = "lotus,sys";
		};

		mipi: mipi@0x11240000 {
			compatible = "lotus,mipi";
			reg = <0x11240000 0x10000>;
			reg-names = "mipi_rx";
			interrupts = <0 45 4>;
			interrupt-names = "mipi_rx";
		};

		vi: vi@11000000 {
			compatible = "lotus,vi";
			reg = <0x11000000 0x200000>, <0x11200000 0x40000>;
			reg-names = "VI_CAP0", "VI_PROC0";
			interrupts = <0 73 4>, <0 70 4>;
			interrupt-names = "VI_CAP0", "VI_PROC0";
		};

		isp: isp@11220000 {
			compatible = "lotus,isp";
			reg = <0x11220000 0x20000>;
			reg-names = "ISP";
			interrupts = <0 73 4>;
			interrupt-names = "ISP";
		};

		pwm: pwm@12080000 {
			compatible = "lotus,pwm";
			reg = <0x12080000 0x1100>;
			reg-names = "PWM";
		};

		piris: piris@120B3000 {
			compatible = "lotus,piris";
			reg = <0x120B3000 0x1000>;
			reg-names = "PIRIS";
		};

		vpss: vpss@11400000 {
			compatible = "lotus,vpss";
			reg = <0x11400000 0x10000>;
			reg-names = "vpss0";
			interrupts = <0 61 4>;
			interrupt-names = "vpss0";
		};

		mcf: mcf {
			compatible = "lotus,mcf";
		};

		gdc: gdc@11480000 {
			compatible = "lotus,gdc";
			reg = <0x11480000 0x10000>;
			reg-names = "gdc";
			interrupts = <0 59 4>;
			interrupt-names = "gdc";
		};

		vo: vo@11280000 {
			compatible = "lotus,vo";
			reg = <0x11280000 0x40000>;
			reg-names = "vo";
			interrupts = <0 74 4>;
			interrupt-names = "vo";
		};

		gfbg: gfbg@11280000 {
			compatible = "lotus,gfbg";
			reg = <0x11280000 0x40000>;
			reg-names = "gfbg";
			interrupts = <0 41 4>;
			interrupt-names = "gfbg";
		};
		tde: tde@112F0000 {
			compatible = "lotus,tde";
			reg = <0x112F0000 0x10000>;
			reg-names = "tde";
			interrupts = <0 65 4>;
			interrupt-names = "tde";
		};
		vgs: vgs@11300000 {
			compatible = "lotus,vgs";
			reg = <0x11300000 0x10000>;
			reg-names = "vgs0";
			interrupts = <0 64 4>;
			interrupt-names = "vgs0";
		};

		npu: npu@11340000 {
			compatible = "lotus,npu";
			reg = <0x11340000 0x10000>;
			reg-names = "npu";
			interrupts = <0 68 4>;
			interrupt-names = "npu";
		};

		gzip: gzip@11310000 {
			compatible = "lotus,gzip";
			reg = <0x11310000 0x10000>;
			reg-names = "gzip";
			interrupts = <0 50 4>;
			interrupt-names = "gzip";
		};

		vedu: vedu@11800000 {
			compatible = "lotus,vedu";
			reg = <0x11800000 0x10000>, <0x11420000 0x10000>, <0x11320000 0x10000>;
			reg-names = "vedu0", "jpge", "scd";
			interrupts = <0 67 4>, <0 60 4>, <0 92 4>;
			interrupt-names = "vedu0","jpge", "scd";
		};

		venc: venc {
			compatible = "lotus,venc";
		};

		aiao: aiao@100e0000 {
			compatible = "lotus,aiao";
			reg = <0x100e0000 0x10000>,<0x100f0000 0x10000>;
			reg-names = "aiao","acodec";
			interrupts = <0 69 4>;
			interrupt-names = "AIO";
			codec-mute-pin = <55 1>;
		};

		ive: ive@11490000 {
			compatible = "lotus,ive";
			reg = <0x11490000 0x10000>;
			reg-names = "ive";
			interrupts = <0 91 4>;
			interrupt-names = "ive";
		};
	};
	#ifdef CONFIG_OPTEE
	firmware {
		optee {
			compatible = "linaro,optee-tz";
			method = "smc";
		};
	};
	#endif
};
