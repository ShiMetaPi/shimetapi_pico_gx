#!/usr/bin/env bash
###############################################################################
#
#  Copyright (c) XMEDIA.
#  All rights reserved.
#  Create By Caizhiyong 2021/3/16
#
###############################################################################

SELF=$(basename ${0})
ROOTDIR=${1}
CMD=${2}

if [ ! -d "${ROOTDIR}" ]; then
	echo "${SELF}: *** Directory \"${ROOTDIR}\" not exists"
	exit 2
fi

cd "${ROOTDIR}"

if [ ! -f init ]; then
	ln -svf sbin/init init
fi

chmod 0755 init
chmod 0755 -R usr/bin usr/sbin usr/lib bin sbin lib
chmod 0755 -R etc/rc
chown 0:0 -R ./*

mknod dev/console c 5 1
mknod dev/ttyAMA0 c 204 64
mknod dev/ttyAMA1 c 204 65
mknod dev/ttyS000 c 204 64
mknod dev/mtdblock0 b 31 0
mknod dev/mtdblock1 b 31 1
mknod dev/mtdblock2 b 31 2
mknod dev/mtdblock3 b 31 3
mknod dev/null c 1 3
mknod dev/zero c 1 5
mknod dev/loop0 b 7 0
mknod dev/loop1 b 7 1
mknod dev/loop2 b 7 2
mknod dev/loop3 b 7 3
ln -s mtdblock3 dev/rootfs

echo ${CMD}
eval ${CMD}
