
menuconfig LOTUS_FMC100
	tristate "Flash Memory Controller V100 support"
	default n
	select MTD_BLOCK
	select MFD_LOTUS_FMC
	help
	  Support Flash Memory Controller V100.

if LOTUS_FMC100

config LOTUS_FMC100_SPINOR
	bool "Spi-Nor Flash support"
	default y
	help
	  Support Spi-Nor Flash Memory.

config LOTUS_FMC100_SPINAND
	bool "Spi-Nand Flash support"
	default n
	help
	  Support Spi-Nand Flash Memory.

config LOTUS_FMC100_NAND
	bool "Nand Flash support"
	default n
	help
	  Support Nand Flash Memory.

config LOTUS_NAND_FS_MAY_NO_YAFFS2
	bool "Remove the restraintion of 16bit ecc type on yaffs2"
	depends on LOTUS_FMC100
	default n
	help
	  The ecc type: 16bit is limited by the flash memory controller,
	  as the yaffs2 tag of rootfs limits the min size of CTRL len is 28.

endif
