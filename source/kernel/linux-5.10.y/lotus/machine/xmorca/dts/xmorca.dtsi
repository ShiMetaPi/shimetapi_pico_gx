		gfbg: gfbg@11280000 {
			compatible = "lotus,gfbg";
			reg = <0x11280000 0x40000>;
			reg-names = "gfbg";
			interrupts = <0 41 4>;
			interrupt-names = "gfbg";
		};
		tde: tde@112F0000 {
			compatible = "lotus,tde";
			reg = <0x112F0000 0x10000>;
			reg-names = "tde";
			interrupts = <0 65 4>;
			interrupt-names = "tde";
		};
		vgs: vgs@11300000 {
			compatible = "lotus,vgs";
			reg = <0x11300000 0x10000>;
			reg-names = "vgs0";
			interrupts = <0 44 4>;
			interrupt-names = "vgs0";
		};

		npu: npu@11340000 {
			compatible = "lotus,npu";
			reg = <0x11340000 0x10000>;
			reg-names = "npu";
			interrupts = <0 46 4>;
			interrupt-names = "npu";
		};

		gzip: gzip@11310000 {
			compatible = "lotus,gzip";
			reg = <0x11310000 0x10000>;
			reg-names = "gzip";
			interrupts = <0 50 4>;
			interrupt-names = "gzip";
		};

		vedu: vedu@11800000 {
			compatible = "lotus,vedu";
			reg = <0x11800000 0x10000>, <0x11420000 0x10000>;
			reg-names = "vedu0", "jpge";
			interrupts = <0 45 4>, <0 40 4>;
